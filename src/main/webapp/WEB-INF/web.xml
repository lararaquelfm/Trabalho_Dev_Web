            <location/>
            <max-file-size>52428800</max-file-size>
            <!-- 50MB -->
            <max-request-size>62914560</max-request-size>
            <!-- 60MB -->
            <file-size-threshold>1048576</file-size-threshold>
            <!-- 1MB -->
        </multipart-config>
    </servlet>
    <servlet>
        <servlet-name>MostrarFotoServlet</servlet-name>
        <servlet-class>controle.foto.MostrarFotoServlet</servlet-class>
